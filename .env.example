# All-In-One-Key environment variable example.
# Copy to .env for local/Docker Compose usage. Do not commit real .env files.

# Application metadata
ALLINONEKEY_APP_VERSION=0.2.0

# Runtime
PORT=8080
GIN_MODE=release

# Persistence
ALLINONEKEY_DB_PATH=data/allinone.db
ALLINONEKEY_DATA_DIR=data

# Security secrets. Replace with strong random values before production use.
ALLINONEKEY_JWT_SECRET=change-me-use-openssl-rand-hex-32
ALLINONEKEY_SESSION_SECRET=change-me-use-openssl-rand-hex-32

# Docker bind-mount ownership. Keep aligned with the host user running Docker.
PUID=1000
PGID=1000

# Frontend build-time fallback version.
VITE_ALLINONEKEY_APP_VERSION=0.2.0
